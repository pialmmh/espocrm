{
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "maxLength": 255
        },
        "chatId": {
            "type": "varchar",
            "maxLength": 255,
            "required": true
        },
        "channel": {
            "type": "enum",
            "options": ["facebook", "whatsapp", "sms", "email"],
            "required": true,
            "style": {
                "facebook": "info",
                "whatsapp": "success",
                "sms": "warning",
                "email": "danger"
            }
        },
        "profilePic": {
            "type": "url"
        },
        "phoneNumber": {
            "type": "phone"
        },
        "emailAddress": {
            "type": "email"
        },
        "relatedLead": {
            "type": "link"
        },
        "relatedContact": {
            "type": "link"
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        }
    },
    "links": {
        "relatedLead": {
            "type": "belongsTo",
            "entity": "Lead"
        },
        "relatedContact": {
            "type": "belongsTo",
            "entity": "Contact"
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc"
    },
    "indexes": {
        "chatIdChannel": {
            "columns": ["chatId", "channel", "deleted"],
            "unique": true
        }
    }
}
