{
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "maxLength": 255
        },
        "channel": {
            "type": "enum",
            "options": ["facebook", "whatsapp", "sms", "email"],
            "required": true,
            "style": {
                "facebook": "info",
                "whatsapp": "success",
                "sms": "warning",
                "email": "danger"
            }
        },
        "credentials": {
            "type": "text",
            "seeMoreDisabled": true
        },
        "isActive": {
            "type": "bool",
            "default": true
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc"
    },
    "indexes": {
        "channel": {
            "columns": ["channel", "deleted"]
        }
    }
}
