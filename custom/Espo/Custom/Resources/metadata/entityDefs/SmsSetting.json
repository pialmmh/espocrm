{
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "maxLength": 100
        },
        "senderId": {
            "type": "varchar",
            "maxLength": 255
        },
        "defaultSender": {
            "type": "varchar",
            "maxLength": 50
        },
        "isActive": {
            "type": "bool",
            "default": true
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc"
    }
}
